{
  "name": "ykosinets",
  "version": "0.0.1",
  "description": "A minimalistic portfolio template.",
  "author": "Yurii Kosynets",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykosinets/portfolio.git"
  },
  "scripts": {
    "prestart": "rimraf build ../index.html ./stats.json",
    "start": "webpack-dev-server --mode development",
    "prebuild": "rimraf build ../index.html ./stats.json",
    "build": "webpack --mode production --progress --display-error-details",
    "prewatch": "rimraf build ../index.html ./stats.json",
    "watch": "webpack --mode development --watch",
    "analyze": "webpack-bundle-analyzer ./stats.json"
  },
  "devDependencies": {
    "@babel/core": "^7.10.4",
    "@babel/plugin-proposal-class-properties": "^7.10.4",
    "@babel/plugin-proposal-object-rest-spread": "^7.10.4",
    "@babel/plugin-transform-async-to-generator": "^7.10.4",
    "@babel/plugin-transform-runtime": "^7.10.4",
    "@babel/preset-env": "^7.10.4",
    "@babel/runtime": "^7.10.4",
    "autoprefixer": "^9.8.4",
    "babel-loader": "^8.1.0",
    "copy-webpack-plugin": "^5.0.4",
    "css-loader": "^3.6.0",
    "csso-webpack-plugin": "^1.0.0-beta.12",
    "extract-loader": "^4.0.3",
    "file-loader": "^4.3.0",
    "html-loader": "^0.5.5",
    "html-webpack-plugin": "^3.2.0",
    "mini-css-extract-plugin": "^0.8.0",
    "sass": "^1.77.8",
    "normalize.css": "^8.0.1",
    "postcss-flexbugs-fixes": "^4.2.1",
    "postcss-loader": "^3.0.0",
    "rimraf": "^3.0.2",
    "sass-loader": "^8.0.0",
    "style-loader": "^1.2.1",
    "webpack": "^4.43.0",
    "webpack-assets-manifest": "^3.1.1",
    "webpack-bundle-analyzer": "^3.8.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.0",
    "webpack-merge": "^4.2.2",
    "webpack-stats-plugin": "0.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "imagemin-webp-webpack-plugin": "^3.3.3"
  }
}
