.journal-signup { min-height: 610px; display: grid; grid-template-columns: .95fr 1.25fr; align-items: center; padding: 90px 210px; gap: 70px; }
.journal-signup h2 { font-size: 76px; line-height: .82; }
.journal-signup p { margin-top: 40px; font-size: 22px; line-height: 1.2; }
@media (max-width: 1200px) { .journal-signup { padding-left: 64px; padding-right: 64px; } }
@media (max-width: 820px) { .journal-signup { grid-template-columns: 1fr; padding: 58px 16px; } .journal-signup h2 { font-size: 48px; } }