.club { min-height: 360px; display: grid; grid-template-columns: .95fr 1.6fr; align-items: center; padding: 70px 210px; gap: 70px; }
.club h2 { color: var(--cream); font-size: 58px; line-height: .86; }
.club img { width: 100%; }
@media (max-width: 1200px) { .club { padding-left: 64px; padding-right: 64px; } }
@media (max-width: 820px) { .club { grid-template-columns: 1fr; gap: 30px; padding: 58px 16px; } }