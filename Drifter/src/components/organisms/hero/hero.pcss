.hero { height: calc(100svh - var(--nav-height)); min-height: 720px; position: relative; overflow: hidden; }
.hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(35,31,32,.28), rgba(35,31,32,.02)); pointer-events: none; }
.hero-slider, .hero-slider .swiper-wrapper, .hero-slider .swiper-slide { position: absolute; inset: 0; width: 100%; height: 100%; }
.hero-slider .swiper-slide img, .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.hero-pagination { bottom: 34px !important; left: auto !important; right: 66px !important; width: auto !important; }
.hero-pagination .swiper-pagination-bullet { width: 10px; height: 10px; border: 1px solid var(--gold); background: transparent; opacity: 1; }
.hero-pagination .swiper-pagination-bullet-active { background: var(--gold); }
.hero-buttons { position: absolute; z-index: 2; right: 315px; bottom: 90px; display: flex; gap: 34px; }
@media (max-width: 1200px) { .hero-buttons { right: 60px; } }
@media (max-width: 820px) { .hero { min-height: calc(100svh - var(--nav-height)); height: auto; padding: 30svh 16px 42px; display: grid; gap: 18px; align-content: end; } .hero-bg { object-position: 42% center; } .hero-buttons { position: relative; inset: auto; display: grid; gap: 12px; } .hero-buttons .btn { width: 100%; } .hero-pagination { right: 18px !important; bottom: 18px !important; } }