.gallery { padding: 0 140px 125px; }
.tabs { min-height: 112px; display: flex; justify-content: flex-end; align-items: center; gap: 42px; font-size: 13px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: rgba(35,31,32,.72); }
.tabs a { color: var(--ink); }
.gallery-grid { display: grid; grid-template-columns: .8fr 1.73fr; gap: 24px; }
.gallery-copy { padding: 58px 0 0 65px; }
.gallery h2 { font-size: 76px; line-height: .82; }
.gallery-copy p:not(.subhead) { max-width: 430px; margin-top: 24px; color: rgba(35,31,32,.7); }
.gallery-copy .btn { margin-top: 28px; }
@media (max-width: 1200px) { .gallery { padding-left: 64px; padding-right: 64px; } }
@media (max-width: 820px) { .gallery { padding: 58px 16px; } .gallery h2 { font-size: 48px; } .tabs { justify-content: flex-start; overflow-x: auto; gap: 22px; min-height: 84px; } .gallery-grid { grid-template-columns: 1fr; grid-template-rows: auto; } .gallery-copy { padding: 0; } }