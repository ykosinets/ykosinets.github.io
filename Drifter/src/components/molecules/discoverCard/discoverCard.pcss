.linked-card { display: block; color: inherit; cursor: pointer; transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, opacity 180ms ease, transform 180ms ease; }
.linked-card img { transition: transform 240ms ease, filter 240ms ease, opacity 240ms ease; }
.linked-card:hover img, .linked-card:focus-visible img { transform: scale(1.025); filter: saturate(1.06) contrast(1.04); }