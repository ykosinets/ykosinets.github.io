{
  "name": "torque-link-media",
  "version": "1.0.0",
  "private": true,
  "description": "Static one-page site for TorqueLink Media.",
  "scripts": {
    "build:css": "postcss src/css/main.css -o styles.css",
    "build:css:min": "NODE_ENV=production postcss src/css/main.css -o styles.min.css",
    "watch:css": "postcss src/css/main.css -o styles.css --watch",
    "lint:css": "stylelint \"src/css/**/*.css\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "serve": "browser-sync start --server . --files \"*.html, styles.css, script.js, assets/**/*\" --no-open",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "browser-sync": "^3.0.3",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ]
}
