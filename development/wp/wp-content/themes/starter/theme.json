{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#111111"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "left": "1.25rem",
        "right": "1.25rem"
      }
    },
    "typography": {
      "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    }
  }
}
